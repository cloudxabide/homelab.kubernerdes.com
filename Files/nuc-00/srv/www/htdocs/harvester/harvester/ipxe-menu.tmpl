#!ipxe
###############################################################################
# Harvester HCI iPXE Network Boot Menu
###############################################################################
#
# BOOT FLOW:
#   1. System PXE boots, loads ipxe.efi from TFTP (nuc-00)
#   2. DHCP sends iPXE client to this menu (http://${ADMIN_IP}/harvester/harvester/ipxe-menu)
#   3. Top-level menu offers a choice of deployment mode: Enclave, Prime, or
#      Community
#   4. Selecting a mode chains to that mode's submenu — enclave.ipxe,
#      prime.ipxe, or community.ipxe — which lists nuc-01/nuc-02/nuc-03 and
#      carries the actual kernel/initrd/rootfs boot parameters for that mode
#   5. Harvester installer reads node config from http://${ADMIN_IP}/harvester/harvester/
#      and proceeds with an automated install (create or join)
#
# Rendered via envsubst — see Scripts/env.sh for ADMIN_IP. nuc-00 serves all
# three deployment modes from one shared web root, so this top-level menu
# only templates ADMIN_IP; per-node hosts, Harvester version, and kernel
# params live in the per-mode enclave.ipxe / prime.ipxe / community.ipxe
# files (see Scripts/env.d/*.sh).
#
# Reference:
#   https://docs.harvesterhci.io/v1.7/install/pxe-boot-install
###############################################################################

# Common parameters for all deployment modes
set base_url   http://${ADMIN_IP}/harvester/
set config_url http://${ADMIN_IP}/harvester/harvester

:start
# Display menu with 5 second timeout (50 x 100ms)
menu Harvester Deployment Menu
item --gap --                   --------------------------------------------
item --key l local                 Boot from local disk (default in 5s)
item --gap --                   --------------Carbide Bits------------------
item enclave_menu		Deploy Harvester for Enclave
item prime_menu			Deploy Harvester for SUSE Prime
item community_menu		Deploy Harvester for Community
item --gap --                   -------------------------------------------
item --key r reboot             Reboot system
item --key s shell              Drop to iPXE shell
choose --timeout 5000 --default local target && goto ${target}

# This references and executes the external Enclave submenu script
:enclave_menu
chain ${config_url}/enclave.ipxe || goto start
goto start

# This references and executes the external Prime submenu script
:prime_menu
chain ${config_url}/prime.ipxe || goto start
goto start

# This references and executes the external Community submenu script
:community_menu
chain ${config_url}/community.ipxe || goto start
goto start

##
# Local and error-handling follows...
:local
echo Booting from local disk...
sanboot --no-describe --drive 0x80 || goto failed

:reboot
echo Rebooting in 2 seconds...
sleep 2
reboot

:shell
echo Dropping to iPXE shell...
shell

:failed
echo Boot failed! Dropping to shell for debugging...
echo Press any key to continue...
prompt
shell
